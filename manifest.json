{
  "manifest_version": 3,
  "name": "VRChat通知転送",
  "description": "VRChatの通知をDiscordに転送する拡張機能です",
  "version": "0.1.1",
  "icons": {
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://vrchat.com/*"
      ],
      "js": [
        "content_scripts.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "embed.js"
      ],
      "matches": [
        "https://vrchat.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "popup",
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab"]
}